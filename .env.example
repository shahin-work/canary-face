# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for Canary Face (Vite). Copy this file to `.env` and fill
# in real values. In Vercel, add the same keys under Settings → Environment
# Variables. All client-exposed vars MUST be prefixed VITE_ (Vite requirement).
#
# NOTE: Firebase web keys are PUBLIC by design — they ship in the browser bundle.
# These are for per-environment config, not secrecy. Security is enforced by the
# Firestore rules (firestore.rules), not by hiding these.
# ─────────────────────────────────────────────────────────────────────────────

# Firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# EmailJS (already used by the app)
VITE_EMAILJS_PUBLIC_KEY=
